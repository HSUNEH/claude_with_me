{
  "hooks": [
    {
      "event": "PreToolUse",
      "matcher": {
        "tool_name": "Edit|Write"
      },
      "commands": [
        {
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/plan-enforcer.sh",
          "timeout": 5000,
          "statusMessage": "CWM: plan check"
        }
      ]
    },
    {
      "event": "PostToolUse",
      "matcher": {
        "tool_name": "Edit|Write|Bash"
      },
      "commands": [
        {
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/change-logger.sh",
          "timeout": 3000,
          "statusMessage": "CWM: logging"
        }
      ]
    },
    {
      "event": "Stop",
      "commands": [
        {
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/completion-checker.sh",
          "timeout": 30000,
          "statusMessage": "CWM: quality check"
        }
      ]
    }
  ]
}
